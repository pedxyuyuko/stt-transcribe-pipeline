output: "{correct.final.result}"
blocks:
  - tag: "stt"
    name: "Speech-to-Text"
    checkpoint: "whisper"
    tasks:
      - tag: "whisper"
        type: "transcriptions"
        model: "openai/whisper-1"
        need_audio: true

  - tag: "correct"
    name: "LLM Correction"
    tasks:
      - tag: "final"
        type: "chat"
        model: "smart"
        max_retries: 2
        timeout: 60
        messages:
          - role: "system"
            content: |
              You are design for fixing STT transcription error with the following steps:
              Please correct it. Rules:
              1. Remove stuttering repetition (e.g. "head head" -> "head")
              2. Remove filler words (um, uh, etc.)
              3. Fix obvious grammar and punctuation errors
              4. Keep the original meaning intact
              Output only the corrected text.
          - role: "user"
            content: |
              {stt.whisper.result}
