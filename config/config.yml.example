host: "0.0.0.0"
port: 8000
api_key: "sk-your-api-key-here"
default_preset: "default"
providers:
  local-qwen:
    base_url: "http://localhost:8000/v1"
    api_key: "none"
  openai:
    base_url: "https://api.openai.com/v1"
    api_key: "sk-your-api-key-here"
model_groups:
  smart:
    - "openai/gpt-4o"
    - "openai/gpt-4o-mini"
