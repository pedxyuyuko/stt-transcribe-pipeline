{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "justMyCode": true,
            "env": {
                "SKIP_AUTH": "true"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Python: pytest (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}"
            ],
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Python: pytest (all tests)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v"
            ],
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}
